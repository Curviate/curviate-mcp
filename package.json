{
  "name": "@curviate/mcp",
  "version": "0.2.0",
  "private": false,
  "description": "Thin stdio bridge to the hosted Curviate MCP endpoint, for stdio-only clients (Claude Desktop, Claude Code, Cursor). Ships no tool implementations; the hosted server is the single source of truth.",
  "license": "MIT",
  "type": "module",
  "mcpName": "com.curviate/mcp",
  "homepage": "https://docs.curviate.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Curviate/curviate-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Curviate/curviate-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "curviate-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "eslint": "^9.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.2"
  }
}
